# =============================================================================
# FinSkillOS — .env.example
# Copy to .env and adjust per environment. Every variable below has a safe
# default in code or docker-compose; the .env file is optional in development.
#
# Layout:
#   1. Python domain layer       (finskillos/config.py)
#   2. PostgreSQL container      (docker-compose postgres service)
#   3. FastAPI service           (api/main.py, api/dependencies.py)
#   4. Vite / React frontend     (frontend/vite.config.ts, src/shared/api/*)
#   5. Playwright e2e runner     (frontend/playwright.config.ts)
#
# Reading order:
#   - finskillos.config.get_settings() calls load_dotenv() unless
#     FINSKILLOS_SKIP_DOTENV=1 is set (used by the pytest suite).
#   - docker compose reads this file automatically when present in the
#     project root; the api / web / e2e services inherit the values via
#     `environment:` interpolation (${VAR:-default}).
# =============================================================================


# --- 1. Python domain layer --------------------------------------------------

APP_ENV=development
FINSKILLOS_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://finskillos:finskillos_dev_password@localhost:5432/finskillos

# Filesystem roots. Each directory is created on demand.
# Postgres state itself lives in the `postgres_data` Docker volume (not here);
# `docker compose down` keeps it — never `down -v` unless you mean to erase it.
# `./fsoctl.sh info` reports these locations and usage.
DATA_DIR=data
CACHE_DIR=data/cache
EXPORT_DIR=data/exports
# Database backups (scripts/backup_postgres.sh / ./fsoctl.sh backup|drill).
BACKUP_DIR=backups

# Goal / account defaults (Slice 03 — 1억 KRW challenge).
FINSKILLOS_BASE_CURRENCY=KRW
FINSKILLOS_TARGET_VALUE=100000000
FINSKILLOS_DEFAULT_ACCOUNT_NAME=Main Trading Account

# Control Room rail staleness thresholds (Slice 78). A market or watchlist
# rail timestamp older than its threshold (in days) is classified STALE.
# The base applies to both rails; per-rail overrides win when set. Must be
# positive integers.
FINSKILLOS_CONTROL_ROOM_STALE_AFTER_DAYS=3
# FINSKILLOS_CONTROL_ROOM_MARKET_STALE_AFTER_DAYS=3
# FINSKILLOS_CONTROL_ROOM_WATCHLIST_STALE_AFTER_DAYS=3

# Market refresh protocol defaults. System Ops uses these when running
# POST /api/system-ops/refresh-market-data. Keep `mock` for deterministic
# local/offline operation; switch to `yahoo` only when live HTTP access is
# intended.
FINSKILLOS_MARKET_REFRESH_ADAPTER=yahoo
FINSKILLOS_MARKET_REFRESH_TICKERS=SPY,QQQ,NVDA,TSLA,AAPL,MSFT,AMZN,SMH,SOXX,VIX,US10Y,DXY
# Bounded retry/backoff for transient market-provider fetch errors (per ticker).
# retries=2 → up to 3 attempts; backoff is exponential (backoff * 2**attempt).
FINSKILLOS_MARKET_FETCH_RETRIES=2
FINSKILLOS_MARKET_FETCH_BACKOFF_SECONDS=1.0

# Indicator calculation reads stored bars only. Keep this aligned with the
# market refresh universe unless you intentionally want a narrower indicator set.
FINSKILLOS_INDICATOR_REFRESH_TICKERS=SPY,QQQ,NVDA,TSLA,AAPL,MSFT,AMZN,SMH,SOXX,VIX,US10Y,DXY

# Optional lightweight worker. Disabled unless the docker compose `worker`
# profile is started. It refreshes market bars, news metadata, and indicators.
FINSKILLOS_WORKER_INTERVAL_SECONDS=86400
FINSKILLOS_WORKER_POLL_SECONDS=5
FINSKILLOS_WORKER_STALE_GRACE_SECONDS=43200
FINSKILLOS_WORKER_RUN_ON_START=1
FINSKILLOS_WORKER_MARKET_ENABLED=1
FINSKILLOS_WORKER_NEWS_ENABLED=1
FINSKILLOS_WORKER_INDICATOR_ENABLED=1
FINSKILLOS_WORKER_REGIME_ENABLED=1
FINSKILLOS_WORKER_PERSIST_INDICATOR_HISTORY=0
# A job stuck in RUNNING longer than this (worker died mid-claim) is reaped to
# ERROR so it can be retried instead of orphaning the queue. 0 disables.
FINSKILLOS_WORKER_RUNNING_STALE_SECONDS=1800
FINSKILLOS_REFRESH_FOLDER_NAMES=
# Worker notification sink (Slice 176): `log` (default — application log),
# `none` to drop, or `telegram` (Slice 177 — requires the token + chat id below;
# falls back to `log` if either is missing). Outbound notifications carry
# operational status only, never trade direction.
FINSKILLOS_NOTIFY_SINK=log
# Telegram adapter (optional, off unless NOTIFY_SINK=telegram). Create a bot via
# @BotFather and find your chat id; both must be set to enable.
FINSKILLOS_TELEGRAM_BOT_TOKEN=
FINSKILLOS_TELEGRAM_CHAT_ID=
FINSKILLOS_NEWS_REFRESH_ADAPTER=rss
FINSKILLOS_NEWS_RSS_FEEDS=
FINSKILLOS_NEWS_RSS_TICKERS=AAPL,MSFT,NVDA,TSLA
FINSKILLOS_NEWS_RSS_SOURCE=
FINSKILLOS_NEWS_RSS_LANGUAGE=en-US

# Symbol Lab arbitrary ticker preview/subscription.
# `preview` fetches a non-persisted provider snapshot when a searched ticker is
# not in DB. `subscribe` controls the provider used after pressing Subscribe.
FINSKILLOS_SYMBOL_PREVIEW_ADAPTER=yahoo
FINSKILLOS_SYMBOL_SUBSCRIBE_ADAPTER=yahoo

# Optional ticker logo provider. Logo.dev uses a publishable image token and
# returns URLs suitable for <img> tags; leave token blank to use local initials.
FINSKILLOS_LOGO_PROVIDER=logo_dev
FINSKILLOS_LOGO_DEV_TOKEN=
# LOGO_DEV_PUBLISHABLE_KEY= also works as an alias.

# Set to "1" to suppress python-dotenv inside finskillos.config when you
# control the environment another way (e.g. CI runners, the pytest suite,
# or production container orchestration).
# FINSKILLOS_SKIP_DOTENV=1


# --- 2. PostgreSQL container -------------------------------------------------

POSTGRES_DB=finskillos
POSTGRES_USER=finskillos
POSTGRES_PASSWORD=finskillos_dev_password
POSTGRES_PORT=5432


# --- 3. FastAPI service (Slice 13.6) ----------------------------------------

# Comma-separated CORS allow-list consumed by api/main.py. The defaults
# cover Vite dev (5173), the nginx-served container (80/3000), and the
# `web` compose service.
FINSKILLOS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://web


# --- 4. Vite / React frontend (Slice 13.6) ----------------------------------

# Where the React app should look for the FastAPI service AT BUILD TIME.
# Defaults to "/api" so the nginx runtime can reverse-proxy to the api
# container without rebuilding when DNS changes.
VITE_API_BASE_URL=/api

# Where Vite's DEV server proxies /api/* during `npm run dev`. Inside
# docker compose this resolves via the `api` service name; on the host
# you usually want http://localhost:8000.
VITE_API_PROXY_TARGET=http://api:8000


# --- 5. Playwright e2e runner (Slice 13.6, docker compose --profile e2e) -----

# URL the Playwright suite targets. Inside docker compose the e2e service
# already sets this to http://web:5173; uncomment when running Playwright
# against a different deployment.
# PLAYWRIGHT_BASE_URL=http://localhost:5173
